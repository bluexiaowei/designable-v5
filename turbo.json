{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**", "esm/**"]
    },
    "build:cjs": {
      "outputs": ["lib/**"]
    },
    "build:esm": {
      "outputs": ["esm/**"]
    },
    "build:playground": {
      "dependsOn": ["^build"],
      "outputs": ["build/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
