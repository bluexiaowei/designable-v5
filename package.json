{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "clean": "rimraf node_modules packages/*/node_modules formily/*/node_modules",
    "build": "turbo run build",
    "build:playground": "turbo run build:playground --filter=@designable-v5/formily-antd",
    "start:antd": "pnpm --filter @designable-v5/formily-antd start",
    "start:playground": "pnpm start:antd",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:prod": "jest --coverage --silent --passWithNoTests",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install",
    "pre:enter": "changeset pre enter",
    "pre:exit": "changeset pre exit",
    "pre:enter:beta": "changeset pre enter beta",
    "pre:enter:alpha": "changeset pre enter alpha",
    "pre:enter:rc": "changeset pre enter rc",
    "release": "pnpm build && changeset publish",
    "release:github": "ts-node scripts/release release",
    "lint": "eslint --ext .ts,.tsx,.js  --fix",
    "postinstall": "opencollective-postinstall"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "@swc/core"
    ],
    "overrides": {
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0",
      "@formily/core": "^2.3.7",
      "@formily/react": "^2.3.7",
      "@formily/shared": "^2.3.7",
      "@formily/reactive": "^2.3.7",
      "@formily/reactive-react": "^2.3.7",
      "yargs": "^16.x"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@swc/core": "^1.10.0",
    "@testing-library/jest-dom": "^5.0.0",
    "@types/fs-extra": "^8.1.0",
    "@types/jest": "^24.0.18",
    "@types/node": "^12.6.8",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^4.9.1",
    "@typescript-eslint/parser": "^4.8.2",
    "antd": "^5.13.0",
    "conventional-commit-types": "^2.2.0",
    "cz-conventional-changelog": "^2.1.0",
    "eslint": "^7.14.0",
    "eslint-config-prettier": "^7.0.0",
    "eslint-plugin-markdown": "^2.0.1",
    "eslint-plugin-prettier": "^3.1.0",
    "eslint-plugin-react": "^7.14.2",
    "execa": "^5.0.0",
    "findup": "^0.1.5",
    "fs-extra": "^7.0.1",
    "gh-release": "^5.0.1",
    "ghooks": "^2.0.4",
    "glob": "^7.1.3",
    "jest": "^26.0.0",
    "lint-staged": "^8.2.1",
    "moment": "^2.30.1",
    "opencollective-postinstall": "^2.0.2",
    "prettier": "^2.2.1",
    "pretty-format": "^24.0.0",
    "pretty-quick": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^3.0.0",
    "semver": "^7.3.5",
    "semver-regex": "^2.0.0",
    "string-similarity": "^4.0.4",
    "ts-jest": "^26.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluexiaowei/designable-v5.git"
  },
  "bugs": {
    "url": "https://github.com/bluexiaowei/designable-v5/issues"
  },
  "homepage": "https://bluexiaowei.github.io/designable-v5/",
  "config": {
    "ghooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "node ./scripts/validate-commit-msg.js"
    },
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    },
    "validate-commit-msg": {
      "maxSubjectLength": 0
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --ext .ts,.tsx,.js --fix",
      "pretty-quick --staged",
      "git add"
    ],
    "*.md": [
      "pretty-quick --staged",
      "git add"
    ]
  }
}
