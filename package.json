{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "clean": "rimraf node_modules packages/*/node_modules formily/*/node_modules apps/*/node_modules",
    "build": "turbo run build",
    "build:playground": "turbo run build:playground --filter=@designable-v5/playground",
    "start:playground": "pnpm --filter @designable-v5/playground dev",
    "test": "vitest",
    "test:prod": "vitest run --passWithNoTests",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install",
    "pre:enter": "changeset pre enter",
    "pre:exit": "changeset pre exit",
    "pre:enter:beta": "changeset pre enter beta",
    "pre:enter:alpha": "changeset pre enter alpha",
    "pre:enter:rc": "changeset pre enter rc",
    "release": "pnpm build && changeset publish",
    "lint": "eslint . --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "@swc/core"
    ],
    "overrides": {
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0",
      "@formily/core": "^2.3.7",
      "@formily/react": "^2.3.7",
      "@formily/shared": "^2.3.7",
      "@formily/reactive": "^2.3.7",
      "@formily/reactive-react": "^2.3.7",
      "yargs": "^16.x"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.22.0",
    "@swc/core": "^1.10.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluexiaowei/designable-v5.git"
  },
  "bugs": {
    "url": "https://github.com/bluexiaowei/designable-v5/issues"
  },
  "homepage": "https://bluexiaowei.github.io/designable-v5/",
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
